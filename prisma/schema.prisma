generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model AuditLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action      String
  entityType  String    @map("entity_type")
  entityId    String?   @map("entity_id") @db.Uuid
  entityName  String?   @map("entity_name")
  changes     Json?     @map("changes")
  severity    String?   @default("info")
  notes       String?
  oldData     Json?     @map("old_data")
  newData     Json?     @map("new_data")
  userId      String?   @map("user_id") @db.Uuid
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user        profiles? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId], map: "idx_audit_entity")
  @@schema("public")
  @@map("audit_logs")
}

model CajaMovement {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        String
  amount      Decimal   @db.Decimal(12, 2)
  description String?
  collectorId String?   @map("collector_id") @db.Uuid
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy   String?   @map("created_by") @db.Uuid

  @@index([collectorId], map: "idx_caja_collector")
  @@schema("public")
  @@map("caja_movements")
}

model CapitalMovement {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            String
  amount          Decimal   @db.Decimal
  previousCapital Decimal   @map("previous_capital") @db.Decimal
  newCapital      Decimal   @map("new_capital") @db.Decimal
  description     String?
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@schema("public")
  @@map("capital_movements")
}

model ChargeOffHistory {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId              String    @map("loan_id") @db.Uuid
  originalCollectorId String?   @map("original_collector_id") @db.Uuid
  recoveryCollectorId String?   @map("recovery_collector_id") @db.Uuid
  amount              Decimal   @db.Decimal
  reason              String?
  status              String?   @default("assigned")
  assignedDate        DateTime  @map("assigned_date") @db.Date
  recoveredDate       DateTime? @map("recovered_date") @db.Date
  notes               String?
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  loan                Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loanId], map: "idx_charge_off_loan")
  @@index([recoveryCollectorId], map: "idx_charge_off_recovery")
  @@schema("public")
  @@map("charge_off_history")
}

model ChatMessage {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderId    String    @map("sender_id") @db.Uuid
  receiverId  String    @map("receiver_id") @db.Uuid
  message     String?
  audioUrl    String?   @map("audio_url")
  isRead      Boolean?  @default(false) @map("is_read")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([createdAt], map: "idx_chat_messages_created")
  @@index([senderId, receiverId], map: "idx_chat_messages_participants")
  @@schema("public")
  @@map("chat_messages")
}

model ClientNote {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String    @map("client_id") @db.Uuid
  createdBy   String?   @map("created_by") @db.Uuid
  note        String
  isImportant Boolean?  @default(false) @map("is_important")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clientId], map: "idx_client_notes_client")
  @@schema("public")
  @@map("client_notes")
}

model Client {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String?
  dni              String?
  phone            String?
  address          String?
  carnetExtranjeria String?       @map("carnet_extranjeria")
  photoUrl         String?        @map("photo_url")
  documentType     String?        @default("peruano") @map("document_type")
  creditScore      Decimal?       @default(50) @map("credit_score") @db.Decimal
  creditScoreLabel String?        @default("Regular") @map("credit_score_label")
  zoneId           String?        @map("zone_id") @db.Uuid
  collectorId      String?        @map("collector_id") @db.Uuid
  latitude         Float?
  longitude        Float?
  createdBy        String?        @map("created_by") @db.Uuid
  createdAt        DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  status           String?        @default("active")
  clientNotes      ClientNote[]
  zone             Zone?          @relation(fields: [zoneId], references: [id], onUpdate: NoAction)
  guarantors       Guarantor[]
  loans            Loan[]
  payments         Payment[]

  @@index([carnetExtranjeria], map: "idx_clients_carnet")
  @@index([collectorId], map: "idx_clients_collector")
  @@index([dni], map: "idx_clients_dni")
  @@index([phone], map: "idx_clients_phone")
  @@index([zoneId], map: "idx_clients_zone")
  @@schema("public")
  @@map("clients")
}

model CollectorCurrentLocation {
  collectorId String    @id @map("collector_id") @db.Uuid
  latitude    Float?
  longitude   Float?
  heading     Float?    @default(0)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@schema("public")
  @@map("collector_current_location")
}

model CollectorExpense {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectorId  String    @map("collector_id") @db.Uuid
  amount       Decimal   @db.Decimal
  category     String
  description  String?
  expenseDate  DateTime  @map("expense_date") @db.Date
  status       String?   @default("pending")
  approvedBy   String?   @map("approved_by") @db.Uuid
  receiptPhoto String?   @map("receipt_photo")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([collectorId], map: "idx_collector_expenses_collector")
  @@index([expenseDate], map: "idx_collector_expenses_date")
  @@index([status], map: "idx_collector_expenses_status")
  @@schema("public")
  @@map("collector_expenses")
}

model CollectorLocation {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectorId  String?   @map("collector_id") @db.Uuid
  latitude     Float?
  longitude    Float?
  heading      Float?    @default(0)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([collectorId], map: "idx_collector_locations_collector_id")
  @@schema("public")
  @@map("collector_locations")
}

model CollectorZone {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectorId  String   @map("collector_id") @db.Uuid
  zoneId       String   @map("zone_id") @db.Uuid
  zone         Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([collectorId, zoneId])
  @@index([collectorId], map: "idx_collector_zones_collector")
  @@schema("public")
  @@map("collector_zones")
}

model DailySettlement {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectorId      String    @map("collector_id") @db.Uuid
  date             DateTime  @db.Date
  expectedCount    Int?      @default(0) @map("expected_count")
  expectedAmount   Decimal?  @default(0) @map("expected_amount") @db.Decimal
  collectedCount   Int?      @default(0) @map("collected_count")
  collectedAmount  Decimal?  @default(0) @map("collected_amount") @db.Decimal
  difference       Decimal?  @default(0) @db.Decimal
  notes            String?
  status           String?   @default("pending")
  approvedBy       String?   @map("approved_by") @db.Uuid
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@unique([collectorId, date])
  @@index([collectorId, date], map: "idx_settlements_collector_date")
  @@schema("public")
  @@map("daily_settlements")
}

model Guarantor {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String    @map("client_id") @db.Uuid
  name      String
  dni       String
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
  @@map("guarantors")
}

model LateFee {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId      String?   @map("loan_id") @db.Uuid
  daysLate    Int       @default(0) @map("days_late")
  amount      Decimal   @default(0) @db.Decimal
  ratePerDay  Decimal?  @default(0) @map("rate_per_day") @db.Decimal
  status      String?   @default("pending")
  generatedAt DateTime? @default(now()) @map("generated_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)
  paidAt      DateTime? @map("paid_at") @db.Timestamp(6)
  waivedAt    DateTime? @map("waived_at") @db.Timestamp(6)
  waivedBy    String?   @map("waived_by") @db.Uuid
  waivedReason String?  @map("waived_reason")
  loan        Loan?     @relation(fields: [loanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loanId], map: "idx_late_fees_loan")
  @@index([status], map: "idx_late_fees_status")
  @@schema("public")
  @@map("late_fees")
}

model Loan {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId            String?            @map("client_id") @db.Uuid
  collectorId         String?            @map("collector_id") @db.Uuid
  zoneId              String?            @map("zone_id") @db.Uuid
  amount              Decimal?           @db.Decimal
  totalAmount         Decimal?           @map("total_amount") @db.Decimal
  interest            Decimal?           @db.Decimal
  days                Int?
  dailyPayment        Decimal?           @map("daily_payment") @db.Decimal
  startDate           DateTime?          @map("start_date") @db.Timestamp(6)
  endDate             DateTime?          @map("end_date") @db.Timestamp(6)
  status              String?            @default("active")
  paymentFrequency    String?            @default("daily") @map("payment_frequency")
  numCuotas           Int?               @default(24) @map("num_cuotas")
  amountPaid          Decimal?           @default(0) @map("amount_paid") @db.Decimal
  notes               String?
  signature           String?
  cancellationReason  String?            @map("cancellation_reason")
  cancelledBy         String?            @map("cancelled_by") @db.Uuid
  cancelledAt         DateTime?          @map("cancelled_at") @db.Timestamp(6)
  completedAt         DateTime?          @map("completed_at") @db.Timestamp(6)
  creditApproved      Boolean?           @default(false) @map("credit_approved")
  chargedOff          Boolean?           @default(false) @map("charged_off")
  chargedOffAt        DateTime?          @map("charged_off_at") @db.Timestamp(6)
  chargedOffBy        String?            @map("charged_off_by") @db.Uuid
  recoveryCollectorId String?            @map("recovery_collector_id") @db.Uuid
  createdBy           String?            @map("created_by") @db.Uuid
  createdAt           DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  nextPaymentDate     DateTime?          @map("next_payment_date") @db.Date
  restDays            String?            @default("") @map("rest_days")
  chargeOffHistory    ChargeOffHistory[]
  lateFees            LateFee[]
  client              Client?            @relation(fields: [clientId], references: [id], onUpdate: NoAction)
  zone                Zone?              @relation(fields: [zoneId], references: [id], onUpdate: NoAction)
  paymentLinks        PaymentLink[]
  paymentSchedule     PaymentSchedule[]
  payments            Payment[]

  @@index([clientId], map: "idx_loans_client")
  @@index([collectorId], map: "idx_loans_collector")
  @@index([status], map: "idx_loans_status")
  @@index([zoneId], map: "idx_loans_zone")
  @@schema("public")
  @@map("loans")
}

model Notification {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  title         String
  body          String
  type          String    @default("info")
  referenceType String?   @map("reference_type")
  referenceId   String?   @map("reference_id")
  isRead        Boolean?  @default(false) @map("is_read")
  pushSent      Boolean?  @default(false) @map("push_sent")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([createdAt], map: "idx_notifications_created")
  @@index([userId, isRead], map: "idx_notifications_unread")
  @@index([userId], map: "idx_notifications_user")
  @@schema("public")
  @@map("notifications")
}

model PaymentLink {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId      String    @map("loan_id") @db.Uuid
  amount      Decimal   @db.Decimal
  token       String    @unique
  status      String?   @default("pending")
  description String?
  expiresAt   DateTime  @map("expires_at") @db.Timestamp(6)
  paidAt      DateTime? @map("paid_at") @db.Timestamp(6)
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  loan        Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loanId], map: "idx_payment_links_loan")
  @@index([status], map: "idx_payment_links_status")
  @@index([token], map: "idx_payment_links_token")
  @@schema("public")
  @@map("payment_links")
}

model PaymentSchedule {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId            String?  @map("loan_id") @db.Uuid
  installmentNumber Int      @map("installment_number")
  amount            Decimal  @db.Decimal
  dueDate           DateTime @map("due_date") @db.Date
  status            String?  @default("pending")
  loan              Loan?    @relation(fields: [loanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loanId], map: "idx_payment_schedule_loan")
  @@schema("public")
  @@map("payment_schedule")
}

model Payment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId             String?   @map("loan_id") @db.Uuid
  collectorId        String?   @map("collector_id") @db.Uuid
  clientId           String?   @map("client_id") @db.Uuid
  amount             Decimal?  @db.Decimal
  interest           Decimal?  @db.Decimal
  paymentMethod      String?   @map("payment_method")
  status             String?   @default("completed")
  observation        String?
  proofPhoto         String?   @map("proof_photo")
  paymentDate        DateTime? @default(now()) @map("payment_date") @db.Date
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy          String?   @map("created_by") @db.Uuid
  cancellationReason String?   @map("cancellation_reason")
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamp(6)
  cancelledBy        String?   @map("cancelled_by") @db.Uuid
  client             Client?   @relation(fields: [clientId], references: [id], onUpdate: NoAction)
  loan               Loan?     @relation(fields: [loanId], references: [id], onUpdate: NoAction)

  @@index([collectorId], map: "idx_payments_collector")
  @@index([paymentDate], map: "idx_payments_date")
  @@index([loanId], map: "idx_payments_loan")
  @@schema("public")
  @@map("payments")
}

model profiles {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid     String?   @unique @map("firebase_uid")
  name            String?
  email           String?
  phone           String?
  dni             String?
  role            String?   @default("collector")
  isActive        Boolean?  @default(true) @map("is_active")
  biometricEnabled Boolean? @default(false) @map("biometric_enabled")
  photoUrl        String?   @map("photo_url")
  dailyGoal       Decimal?  @default(0) @map("daily_goal") @db.Decimal
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  zoneId          String?   @map("zone_id") @db.Uuid
  documentType    String?   @map("document_type")
  address         String?
  zone            Zone?       @relation(fields: [zoneId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  auditLogs       AuditLog[]

  @@index([dni], map: "idx_profiles_dni")
  @@index([phone], map: "idx_profiles_phone")
  @@index([zoneId], map: "idx_profiles_zone_id")
  @@schema("public")
  @@map("profiles")
}

model Setting {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capital Decimal? @default(0) @db.Decimal

  @@schema("public")
  @@map("settings")
}

model Zone {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  clients         Client[]
  collectorZones  CollectorZone[]
  loans           Loan[]
  profiles        profiles[]

  @@schema("public")
  @@map("zones")
}
