generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model audit_logs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action      String
  entity_type String
  entity_id   String?   @db.Uuid
  old_data    Json?
  new_data    Json?
  user_id     String?   @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([entity_type, entity_id], map: "idx_audit_entity")
  @@schema("public")
}

model caja_movements {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         String
  amount       Decimal   @db.Decimal(12, 2)
  description  String?
  collector_id String?   @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  created_by   String?   @db.Uuid

  @@index([collector_id], map: "idx_caja_collector")
  @@schema("public")
}

model capital_movements {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type             String
  amount           Decimal   @db.Decimal
  previous_capital Decimal   @db.Decimal
  new_capital      Decimal   @db.Decimal
  description      String?
  created_at       DateTime? @default(now()) @db.Timestamp(6)

  @@schema("public")
}

model charge_off_history {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_id               String    @db.Uuid
  original_collector_id String?   @db.Uuid
  recovery_collector_id String?   @db.Uuid
  amount                Decimal   @db.Decimal
  reason                String?
  status                String?   @default("assigned")
  assigned_date         DateTime  @db.Date
  recovered_date        DateTime? @db.Date
  notes                 String?
  created_at            DateTime? @default(now()) @db.Timestamp(6)
  loans                 loans     @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loan_id], map: "idx_charge_off_loan")
  @@index([recovery_collector_id], map: "idx_charge_off_recovery")
  @@schema("public")
}

model chat_messages {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id   String    @db.Uuid
  receiver_id String    @db.Uuid
  message     String?
  audio_url   String?
  is_read     Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  @@index([created_at], map: "idx_chat_messages_created")
  @@index([sender_id, receiver_id], map: "idx_chat_messages_participants")
  @@schema("public")
}

model client_notes {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id    String    @db.Uuid
  created_by   String?   @db.Uuid
  note         String
  is_important Boolean?  @default(false)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  clients      clients   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([client_id], map: "idx_client_notes_client")
  @@schema("public")
}

model clients {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String?
  dni                String?
  phone              String?
  address            String?
  carnet_extranjeria String?
  photo_url          String?
  document_type      String?       @default("peruano")
  credit_score       Decimal?      @default(50) @db.Decimal
  credit_score_label String?       @default("Regular")
  zone_id            String?       @db.Uuid
  collector_id       String?       @db.Uuid
  latitude           Float?
  longitude          Float?
  created_by         String?       @db.Uuid
  created_at         DateTime?     @default(now()) @db.Timestamp(6)
  status             String?       @default("active")
  client_notes       client_notes[]
  zones              zones?        @relation(fields: [zone_id], references: [id], onUpdate: NoAction)
  guarantors         guarantors[]
  loans              loans[]
  payments           payments[]

  @@index([carnet_extranjeria], map: "idx_clients_carnet")
  @@index([collector_id], map: "idx_clients_collector")
  @@index([dni], map: "idx_clients_dni")
  @@index([phone], map: "idx_clients_phone")
  @@index([zone_id], map: "idx_clients_zone")
  @@index([zone_id], map: "idx_clients_zone_id")
  @@schema("public")
}

model collector_current_location {
  collector_id String    @id @db.Uuid
  latitude     Float?
  longitude    Float?
  heading      Float?    @default(0)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)

  @@schema("public")
}

model collector_expenses {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collector_id  String    @db.Uuid
  amount        Decimal   @db.Decimal
  category      String
  description   String?
  expense_date  DateTime  @db.Date
  status        String?   @default("pending")
  approved_by   String?   @db.Uuid
  receipt_photo String?
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  @@index([collector_id], map: "idx_collector_expenses_collector")
  @@index([expense_date], map: "idx_collector_expenses_date")
  @@index([status], map: "idx_collector_expenses_status")
  @@schema("public")
}

model collector_locations {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collector_id String?   @db.Uuid
  latitude     Float?
  longitude    Float?
  heading      Float?    @default(0)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)

  @@index([collector_id], map: "idx_collector_locations_collector_id")
  @@schema("public")
}

model collector_zones {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collector_id String   @db.Uuid
  zone_id      String   @db.Uuid
  zones        zones    @relation(fields: [zone_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([collector_id, zone_id])
  @@index([collector_id], map: "idx_collector_zones_collector")
  @@schema("public")
}

model daily_settlements {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collector_id    String    @db.Uuid
  date            DateTime  @db.Date
  expected_count  Int?      @default(0)
  expected_amount Decimal?  @default(0) @db.Decimal
  collected_count Int?      @default(0)
  collected_amount Decimal? @default(0) @db.Decimal
  difference      Decimal?  @default(0) @db.Decimal
  notes           String?
  status          String?   @default("pending")
  approved_by     String?   @db.Uuid
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  @@unique([collector_id, date])
  @@index([collector_id, date], map: "idx_settlements_collector_date")
  @@schema("public")
}

model guarantors {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id  String    @db.Uuid
  name       String
  dni        String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  clients    clients   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model late_fees {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_id       String?   @db.Uuid
  days_late     Int       @default(0)
  amount        Decimal   @default(0) @db.Decimal
  rate_per_day  Decimal?  @default(0) @db.Decimal
  status        String?   @default("pending")
  generated_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  paid_at       DateTime? @db.Timestamp(6)
  waived_at     DateTime? @db.Timestamp(6)
  waived_by     String?   @db.Uuid
  waived_reason String?
  loans         loans?    @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loan_id], map: "idx_late_fees_loan")
  @@index([status], map: "idx_late_fees_status")
  @@schema("public")
}

model loans {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id             String?              @db.Uuid
  collector_id          String?              @db.Uuid
  zone_id               String?              @db.Uuid
  amount                Decimal?             @db.Decimal
  total_amount          Decimal?             @db.Decimal
  interest              Decimal?             @db.Decimal
  days                  Int?
  daily_payment         Decimal?             @db.Decimal
  start_date            DateTime?            @db.Timestamp(6)
  end_date              DateTime?            @db.Timestamp(6)
  status                String?              @default("active")
  payment_frequency     String?              @default("daily")
  num_cuotas            Int?                 @default(24)
  amount_paid           Decimal?             @default(0) @db.Decimal
  notes                 String?
  signature             String?
  cancellation_reason   String?
  cancelled_by          String?              @db.Uuid
  cancelled_at          DateTime?            @db.Timestamp(6)
  completed_at          DateTime?            @db.Timestamp(6)
  credit_approved       Boolean?             @default(false)
  charged_off           Boolean?             @default(false)
  charged_off_at        DateTime?            @db.Timestamp(6)
  charged_off_by        String?              @db.Uuid
  recovery_collector_id String?              @db.Uuid
  created_by            String?              @db.Uuid
  created_at            DateTime?            @default(now()) @db.Timestamp(6)
  next_payment_date     DateTime?            @db.Date
  rest_days             String?              @default("")
  charge_off_history    charge_off_history[]
  late_fees             late_fees[]
  clients               clients?             @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  zones                 zones?               @relation(fields: [zone_id], references: [id], onUpdate: NoAction)
  payment_links         payment_links[]
  payment_schedule      payment_schedule[]
  payments              payments[]

  @@index([client_id], map: "idx_loans_client")
  @@index([collector_id], map: "idx_loans_collector")
  @@index([status], map: "idx_loans_status")
  @@index([zone_id], map: "idx_loans_zone")
  @@schema("public")
}

model notifications {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  title          String
  body           String
  type           String    @default("info")
  reference_type String?
  reference_id   String?
  is_read        Boolean?  @default(false)
  push_sent      Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.Timestamp(6)

  @@index([created_at], map: "idx_notifications_created")
  @@index([user_id, is_read], map: "idx_notifications_unread")
  @@index([user_id], map: "idx_notifications_user")
  @@schema("public")
}

model payment_links {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_id     String    @db.Uuid
  amount      Decimal   @db.Decimal
  token       String    @unique
  status      String?   @default("pending")
  description String?
  expires_at  DateTime  @db.Timestamp(6)
  paid_at     DateTime? @db.Timestamp(6)
  created_by  String?   @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  loans       loans     @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loan_id], map: "idx_payment_links_loan")
  @@index([status], map: "idx_payment_links_status")
  @@index([token], map: "idx_payment_links_token")
  @@schema("public")
}

model payment_schedule {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_id            String?  @db.Uuid
  installment_number Int
  amount             Decimal  @db.Decimal
  due_date           DateTime @db.Date
  status             String?  @default("pending")
  loans              loans?   @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loan_id], map: "idx_payment_schedule_loan")
  @@schema("public")
}

model payments {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_id           String?   @db.Uuid
  collector_id      String?   @db.Uuid
  client_id         String?   @db.Uuid
  amount            Decimal?  @db.Decimal
  interest          Decimal?  @db.Decimal
  payment_method    String?
  status            String?   @default("completed")
  observation       String?
  proof_photo       String?
  payment_date      DateTime? @default(now()) @db.Date
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  created_by        String?   @db.Uuid
  cancellation_reason String?
  cancelled_at      DateTime? @db.Timestamp(6)
  cancelled_by      String?   @db.Uuid
  clients           clients?  @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  loans             loans?    @relation(fields: [loan_id], references: [id], onUpdate: NoAction)

  @@index([collector_id], map: "idx_payments_collector")
  @@index([payment_date], map: "idx_payments_date")
  @@index([loan_id], map: "idx_payments_loan")
  @@schema("public")
}

model profiles {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebase_uid    String?                     @unique
  name            String?
  email           String?
  phone           String?
  dni             String?
  role            String?                     @default("collector")
  is_active       Boolean?                    @default(true)
  biometric_enabled                           Boolean? @default(false)
  photo_url       String?
  daily_goal      Decimal?                    @default(0) @db.Decimal
  created_at      DateTime?                   @default(now()) @db.Timestamp(6)
  zone_id         String?                     @db.Uuid
  document_type   String?
  address         String?
  zones           zones?                      @relation(fields: [zone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([dni], map: "idx_profiles_dni")
  @@index([phone], map: "idx_profiles_phone")
  @@index([zone_id], map: "idx_profiles_zone_id")
  @@schema("public")
}

model settings {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capital Decimal? @default(0) @db.Decimal

  @@schema("public")
}

model zones {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  clients         clients[]
  collector_zones collector_zones[]
  loans           loans[]
  profiles        profiles[]

  @@schema("public")
}
